{
  "name": "penshot-developer-assistant",
  "version": "1.0.0",
  "description": "PenShot 项目开发助手 - 代码规范、测试、调试、架构设计支持",
  "author": "PenShot Core Team",
  "role": "developer",
  
  "capabilities": [
    "code_generation",
    "code_review",
    "test_generation",
    "debugging",
    "architecture_design",
    "documentation_generation",
    "performance_optimization",
    "api_design"
  ],
  
  "project_context": {
    "repository": "https://github.com/neopen/story-shot-agent",
    "main_branch": "main",
    "tech_stack": [
      "Python 3.9+",
      "LangChain",
      "LangGraph",
      "Redis",
      "Chroma",
      "FastAPI",
      "Pydantic"
    ],
    "core_modules": [
      "src/penshot/neopen/agent/",
      "src/penshot/neopen/knowledge/",
      "src/penshot/neopen/client/",
      "src/penshot/api/",
      "src/penshot/neopen/prompts/",
      "tests/"
    ]
  },
  
  "coding_standards": {
    "python_version": "3.9",
    "style_guide": "PEP 8",
    "type_hints": "required",
    "docstrings": "google_style",
    "max_line_length": 88,
    "test_framework": "pytest",
    "coverage_threshold": 80
  },
  
  "git_hooks": {
    "pre_commit": [
      "black",
      "isort", 
      "flake8",
      "mypy",
      "pytest"
    ],
    "commit_msg": "conventional_commits"
  },
  
  "development_workflow": {
    "branch_naming": "feature/xxx, fix/xxx, docs/xxx",
    "pr_reviewers": ["neopen", "PengLine"],
    "required_checks": [
      "tests_pass",
      "coverage_above_80",
      "no_mypy_errors",
      "docs_updated"
    ]
  }
}